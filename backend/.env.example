# Copy this file to `.env` and fill in your values.
# Never commit your real `.env` file.

# ---- General -----------------------------------------------------------
APP_NAME=AI Assistant
ENVIRONMENT=development
LOG_LEVEL=INFO

# Comma-separated list of frontend origins allowed to call this API.
CORS_ORIGINS=http://localhost:5173

# ---- LLM provider --------------------------------------------------------
# Currently supported: gemini
LLM_PROVIDER=gemini

# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Other options: gemini-2.5-pro, gemini-3-pro-preview, gemini-3.5-flash, etc.
# Check https://ai.google.dev/gemini-api/docs/models for the current list.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7

# ---- Embeddings provider (for future RAG use) -----------------------------
# Currently supported: gemini
EMBEDDINGS_PROVIDER=gemini
GEMINI_EMBEDDINGS_MODEL=models/text-embedding-004

# Uncomment and fill these in if you add an OpenAI/Voyage embeddings provider later.
# OPENAI_API_KEY=
# OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
# VOYAGE_API_KEY=
# VOYAGE_EMBEDDINGS_MODEL=voyage-3

# ---- Feature flags ---------------------------------------------------------
# Turn these on once you're ready to use them.
ENABLE_WEB_SEARCH_TOOL=false
ENABLE_RAG_TOOL=false

# ---- Memory -----------------------------------------------------------------
# "memory" (resets on restart) or "sqlite" (persisted to a local file)
CHECKPOINTER_BACKEND=memory
SQLITE_CHECKPOINT_PATH=./checkpoints.sqlite
